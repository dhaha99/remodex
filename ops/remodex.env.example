# Copy this file to ops/remodex.env and adjust values before production use.

REMODEX_WORKSPACE="/Users/mymac/my dev/remodex"
REMODEX_SHARED_BASE="/Users/mymac/my dev/remodex/runtime/external-shared-memory"
REMODEX_WORKSPACE_KEY="remodex"

# Codex app-server websocket listener.
CODEX_APP_SERVER_WS_URL="ws://127.0.0.1:4517"

# Discord/operator ingress bridge.
REMODEX_OPERATOR_HTTP_HOST="127.0.0.1"
REMODEX_OPERATOR_HTTP_PORT="8787"
REMODEX_DISCORD_PUBLIC_KEY_PATH="/absolute/path/to/discord_public.pem"
REMODEX_AUTO_CONSUME_HUMAN_GATE="false"

# launchd generation.
REMODEX_NODE_BIN="/opt/homebrew/bin/node"
REMODEX_LAUNCHD_LABEL_PREFIX="com.remodex"
REMODEX_SCHEDULER_INTERVAL_SECONDS="60"

