# Copy this file to ops/remodex.env and adjust values before production use.

REMODEX_WORKSPACE="/absolute/path/to/remodex"
REMODEX_SHARED_BASE="/absolute/path/to/remodex/runtime/external-shared-memory"
REMODEX_WORKSPACE_KEY="remodex"

# Codex app-server websocket listener.
CODEX_APP_SERVER_WS_URL="ws://127.0.0.1:4517"

# Discord/operator ingress bridge.
REMODEX_OPERATOR_HTTP_HOST="127.0.0.1"
REMODEX_OPERATOR_HTTP_PORT="8787"
REMODEX_DASHBOARD_HTTP_HOST="127.0.0.1"
REMODEX_DASHBOARD_HTTP_PORT="8790"
REMODEX_DISCORD_PUBLIC_KEY_PATH=""
REMODEX_AUTO_CONSUME_HUMAN_GATE="false"

# Canonical Discord production ingress (Gateway adapter).
REMODEX_DISCORD_GATEWAY_URL="wss://gateway.discord.gg/?v=10&encoding=json"
REMODEX_DISCORD_GATEWAY_INTENTS="33281"
REMODEX_DISCORD_API_BASE_URL="https://discord.com/api/v10"
REMODEX_DISCORD_OUTBOX_POLL_INTERVAL_MS="2000"
REMODEX_DISCORD_GATEWAY_APP_SERVER_LOG_PATH="/absolute/path/to/remodex/runtime/external-shared-memory/remodex/router/discord_gateway_app_server.jsonl"
REMODEX_DISCORD_APPLICATION_ID="discord_application_id"
REMODEX_DISCORD_BOT_TOKEN_PATH="/absolute/path/to/discord_bot_token.txt"
REMODEX_DISCORD_GUILD_ID="discord_guild_id_for_fast_sync"
REMODEX_DISCORD_LIVE_PROOF_DIR="/absolute/path/to/remodex/runtime/live-discord-proof"
REMODEX_DISCORD_LIVE_PROOF_REGISTER_COMMANDS="true"
REMODEX_DISCORD_LIVE_PROOF_EXPECT_INTERACTION="false"
REMODEX_DISCORD_LIVE_PROOF_TIMEOUT_MS="120000"
REMODEX_ENABLE_DISCORD_GATEWAY_ADAPTER="false"
REMODEX_ENABLE_DASHBOARD_SERVER="false"

# Scheduler bootstrap.
REMODEX_SCHEDULER_KIND="launchd_launchagent"
REMODEX_NODE_BIN="/absolute/path/to/node"
REMODEX_LAUNCHD_LABEL_PREFIX="com.remodex"
REMODEX_WINDOWS_TASK_PREFIX="Remodex"
REMODEX_SCHEDULER_INTERVAL_SECONDS="60"
